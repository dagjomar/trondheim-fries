---
import BaseHead from '../components/BaseHead.astro';
import SiteTopBar from '../components/SiteTopBar.astro';
import SiteBottomNav from '../components/SiteBottomNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import Hero from '../components/sections/Hero.astro';
import Leaderboard from '../components/sections/Leaderboard.astro';
import ArchivePreview from '../components/sections/ArchivePreview.astro';
import StatsStrip from '../components/sections/StatsStrip.astro';
---

<!doctype html>
<html lang="no">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="landing">
		<SiteTopBar />
		<main>
			<Hero />
			<Leaderboard />
			<ArchivePreview />
			<StatsStrip />
		</main>
		<SiteFooter />
		<SiteBottomNav />
	</body>
</html>

<style>
	.landing main {
		display: grid;
		gap: var(--space-6);
		padding-top: var(--top-bar-height);
		padding-bottom: calc(5rem + env(safe-area-inset-bottom, 0));
	}

	@media (min-width: 768px) {
		.landing main {
			padding-bottom: var(--space-6);
		}
	}
</style>
