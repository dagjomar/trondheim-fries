---
---

<header class="site-nav">
	<div class="site-nav-inner">
		<a class="wordmark" href="#hero">TRD_FRIES</a>

		<nav class="nav-jump" aria-label="Snarvei til lederne">
			<a class="jump-link" href="#leaderboard">Lederne</a>
		</nav>
	</div>
</header>

<style>
	.site-nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 50;
		min-height: var(--top-bar-height);
		display: flex;
		align-items: center;
		background: var(--color-nav-bg);
		border-bottom: var(--border-thin) solid var(--color-outline);
	}

	.site-nav-inner {
		width: 100%;
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 clamp(0.75rem, 3vw, 1.25rem);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-2);
		min-height: var(--top-bar-height);
	}

	.wordmark {
		font-family: var(--font-display);
		font-size: clamp(1.05rem, 3.2vw, 1.35rem);
		font-weight: 900;
		font-style: italic;
		text-transform: uppercase;
		letter-spacing: -0.045em;
		color: var(--color-accent-gold);
		text-decoration: none;
		line-height: 1;
		white-space: nowrap;
		flex-shrink: 0;
	}

	.wordmark:hover {
		color: var(--color-accent-gold-dim);
	}

	.nav-jump {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.35rem 0.75rem;
		flex-wrap: wrap;
	}

	.jump-link {
		font-family: var(--font-meta);
		font-size: 0.6875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: color-mix(in oklab, var(--color-text) 72%, transparent);
		text-decoration: none;
		padding: 0.2rem 0;
		border-bottom: 1px solid transparent;
		transition:
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.jump-link:hover {
		color: var(--color-accent-gold);
		border-bottom-color: var(--color-accent-gold);
	}
</style>
