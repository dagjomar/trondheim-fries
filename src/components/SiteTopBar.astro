---
---

<header class="site-nav">
	<div class="site-nav-inner">
		<a class="wordmark" href="/">TRD_FRIES</a>

		<nav class="nav-desktop" aria-label="Primær navigasjon">
			<a class="nav-link nav-active" href="#archive">ARKIV</a>
			<a class="nav-link" href="#">KART</a>
			<a class="nav-link" href="/about">OM OSS</a>
		</nav>

		<div class="nav-actions">
			<button type="button" class="btn-abonn"> ABONNER </button>
			<button type="button" class="btn-meny" aria-label="Meny">
				<span class="material-symbols-outlined">menu</span>
			</button>
		</div>
	</div>
</header>

<style>
	.site-nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 50;
		height: var(--top-bar-height);
		display: flex;
		align-items: stretch;
		background: var(--color-nav-bg);
		border-bottom: var(--border-nav) solid var(--color-text);
	}

	.site-nav-inner {
		width: 100%;
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 clamp(1rem, 4vw, 1.5rem);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-2);
	}

	.wordmark {
		font-family: var(--font-display);
		font-size: clamp(1.25rem, 3.5vw, 1.75rem);
		font-weight: 900;
		font-style: italic;
		text-transform: uppercase;
		letter-spacing: -0.045em;
		color: var(--color-accent-gold);
		text-decoration: none;
		line-height: 1;
		white-space: nowrap;
	}

	.wordmark:hover {
		color: var(--color-accent-gold-dim);
	}

	.nav-desktop {
		display: none;
		align-items: stretch;
		height: 100%;
	}

	@media (min-width: 768px) {
		.nav-desktop {
			display: flex;
		}

		.btn-meny {
			display: none;
		}
	}

	.nav-link {
		display: flex;
		align-items: center;
		align-self: stretch;
		padding: 0 1rem;
		font-family: var(--font-display);
		font-size: clamp(0.75rem, 1.5vw, 0.9375rem);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: -0.03em;
		color: var(--color-text);
		text-decoration: none;
		transition:
			background 0.18s ease,
			color 0.18s ease;
		border-radius: var(--radius-none);
	}

	.nav-link:hover {
		background: var(--color-text);
		color: var(--color-nav-bg);
	}

	.nav-active {
		background: var(--color-accent-gold);
		color: #0f0f0f;
	}

	.nav-active:hover {
		background: var(--color-accent-gold-dim);
		color: #0f0f0f;
	}

	.nav-actions {
		display: flex;
		align-items: stretch;
		gap: 0;
		margin-right: calc(-1 * clamp(1rem, 4vw, 1.5rem));
		align-self: stretch;
	}

	.btn-abonn {
		display: none;
		align-items: center;
		padding: 0 1rem;
		font-family: var(--font-display);
		font-size: clamp(0.65rem, 1.5vw, 0.6875rem);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-accent-gold);
		background: transparent;
		border: var(--border-thin) solid var(--color-accent-gold);
		cursor: pointer;
		transition:
			background 0.18s ease,
			color 0.18s ease;
		border-radius: var(--radius-none);
		white-space: nowrap;
	}

	@media (min-width: 480px) {
		.btn-abonn {
			display: flex;
		}

		.nav-actions {
			margin-right: 0;
		}
	}

	.btn-abonn:hover {
		background: var(--color-accent-gold);
		color: #221b00;
	}

	.btn-meny {
		display: flex;
		align-items: center;
		justify-content: center;
		min-width: 3.75rem;
		padding: 0 1rem;
		color: var(--color-accent-gold);
		background: transparent;
		border: none;
		border-left: var(--border-thin) solid var(--color-outline);
		cursor: pointer;
		transition:
			background 0.18s ease,
			color 0.18s ease;
		align-self: stretch;
		height: auto;
		min-height: 100%;
	}

	.btn-meny:hover {
		background: var(--color-text);
		color: var(--color-nav-bg);
	}

	.btn-meny .material-symbols-outlined {
		font-size: 1.75rem;
	}
</style>
