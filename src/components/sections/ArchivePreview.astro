---
import Container from '../primitives/Container.astro';
import SectionHeader from '../primitives/SectionHeader.astro';
import Rule from '../primitives/Rule.astro';
import MetaTag from '../primitives/MetaTag.astro';

const imgFeatured =
	'https://lh3.googleusercontent.com/aida-public/AB6AXuBiUjjRDFXRv3VkXmEUlPL-dlFveds9hJ0twLTgNJFQGqiFC1S2tDIeEakZu7DHzI2kFJer_3tiQjrKMFLj9LseoQvrHaOkDq0YaO15UeA0H_reFsY-UVXiqrM28NAoaA3-Cs0-FKjDpbmOU_6k0GU2TQrkhoQJuxg8xVu4inc9g2fnUfLcWCC0aHzbLHzVbvgi283P1NFer9T7f5jAvNw2kkks5i_WpKQiCt8BXweq0XS4OUpzS2tPEScJbmUuNgNgP84fSjRxhA';
const imgThumb =
	'https://lh3.googleusercontent.com/aida-public/AB6AXuDLA3x6uVpOLR8WSS_zzlWppn3uKgaJuvlK7mUfTylKRZSenYTUpIucW_7pp1MsAnxSUXo5jkzKP-Vm4aRig67p57gqalzp-AXBs9mbz4JdXTRk0dNTSbMq8dkt29tWAJ3vU12aEF5v3KvEwjoRrMzgUPLTwn7CQNryujXd8hugth5ma1CwM5-8Wf9lAanomPz3_5ht8JbXFAAR5pzZIWRhqxFBhb6hOYIWM-DNQo0I5u0Kk3iEPVDOGj5p7cDCKg_9Y9jM9SIbPA';
---

<Container as="section" class="panel" id="archive">
	<SectionHeader index="02" title="ARKIVET" />
	<Rule />
	<div class="archive-layout">
		<article class="feature">
			<div class="feature-media">
				<img
					src={imgFeatured}
					alt=""
					width="1200"
					height="675"
					loading="lazy"
					decoding="async"
					class="feature-img"
				/>
			</div>
			<div class="feature-body">
				<MetaTag>Utvalgt fra Trondheim</MetaTag>
				<h3 class="feature-title">Den trippelstekte monolitten</h3>
				<div class="feature-row">
					<div class="score-block">
						<span class="score-label">Poengsum</span>
						<span class="score-value">9,4</span>
					</div>
					<div class="feature-copy">
						<div class="score-bar" aria-hidden="true">
							<span class="score-bar-fill"></span>
						</div>
						<p>
							Lokalt mandelpotet-materiale, dobbeltsving i frityren og konsistent saltplanet i hver
							batch. Referansen for strukturell fryteknologi i nord.
						</p>
					</div>
				</div>
			</div>
		</article>
		<div class="sidebar">
			<article class="thumb-card">
				<div class="thumb-media">
					<img
						src={imgThumb}
						alt=""
						width="600"
						height="600"
						loading="lazy"
						decoding="async"
						class="thumb-img"
					/>
				</div>
				<MetaTag>Oppføring #402</MetaTag>
				<h4 class="thumb-title">Krydrede tallow-strimler</h4>
				<div class="thumb-footer">
					<span class="thumb-meta">SPRØHET · HØY</span>
					<span class="material-symbols-outlined thumb-arrow">arrow_forward</span>
				</div>
			</article>
			<article class="note">
				<MetaTag>Arkivnotat</MetaTag>
				<p>
					Grensen mellom snack og struktur dokumenteres teknisk. Hver post har eget smaksdiagram og teksturbeskrivelse.
				</p>
			</article>
		</div>
	</div>
</Container>

<style>
	.panel {
		padding-top: var(--space-2);
	}

	.archive-layout {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-3);
		margin-top: var(--space-3);
	}

	.feature {
		border: var(--border-thin) solid var(--color-outline);
		background: var(--color-surface);
		overflow: hidden;
		display: flex;
		flex-direction: column;
	}

	.feature-media {
		aspect-ratio: 16 / 9;
		background: var(--color-surface-3);
		overflow: hidden;
	}

	.feature-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: grayscale(1);
		transition: filter 0.7s ease;
	}

	.feature:hover .feature-img {
		filter: grayscale(0);
	}

	.feature-body {
		padding: var(--space-3);
	}

	.feature-title {
		margin-top: var(--space-1);
		margin-bottom: var(--space-3);
		font-size: var(--text-headline-lg);
	}

	.feature-row {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-3);
		align-items: start;
	}

	.score-block {
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
	}

	.score-label {
		font-family: var(--font-meta);
		font-size: var(--text-label);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-outline-strong);
	}

	.score-value {
		font-family: var(--font-display);
		font-size: var(--text-headline-lg);
		color: var(--color-accent-gold);
		line-height: 1;
	}

	.feature-copy p {
		margin: var(--space-2) 0 0;
		color: var(--color-text-muted);
		font-size: var(--text-body-md);
	}

	.score-bar {
		height: 4px;
		background: var(--color-surface-3);
		width: 100%;
	}

	.score-bar-fill {
		display: block;
		height: 100%;
		width: 100%;
		background: var(--color-accent-gold);
	}

	.sidebar {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	.thumb-card {
		border: var(--border-thin) solid var(--color-outline);
		background: var(--color-surface-lowest);
		padding: var(--space-3);
	}

	.thumb-media {
		aspect-ratio: 1;
		background: var(--color-surface-3);
		margin-bottom: var(--space-2);
		overflow: hidden;
	}

	.thumb-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: grayscale(1);
	}

	.thumb-title {
		margin-top: var(--space-1);
		margin-bottom: 0;
		font-size: var(--text-headline-md);
		font-weight: 500;
	}

	.thumb-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-top: var(--space-3);
		padding-top: var(--space-2);
		border-top: var(--border-thin) solid var(--color-outline);
	}

	.thumb-meta {
		font-family: var(--font-meta);
		font-size: var(--text-meta);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-text-muted);
	}

	.thumb-arrow {
		color: var(--color-accent-gold);
		font-size: 1.25rem;
	}

	.note {
		border: var(--border-thin) solid var(--color-outline);
		background: var(--color-surface-lowest);
		padding: var(--space-3);
	}

	.note p {
		margin: var(--space-2) 0 0;
		color: var(--color-text-muted);
		font-size: var(--text-body-md);
	}

	@media (min-width: 900px) {
		.archive-layout {
			grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
		}

		.feature-row {
			grid-template-columns: auto 1fr;
			align-items: center;
		}
	}
</style>
