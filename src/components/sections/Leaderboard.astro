---
import Container from '../primitives/Container.astro';

type Leader = {
	rank: number;
	name: string;
	score: string;
	blurb: string;
	updated: string;
	image?: string;
};

const leaders: Leader[] = [
	{
		rank: 1,
		name: 'SuperHero Burger',
		score: '9.8',
		blurb: 'Trippel-tilberedt med en tekstur som trosser tyngdekraften.',
		updated: '12.05.2024',
		image:
			'https://lh3.googleusercontent.com/aida-public/AB6AXuDjRHok5M5gQtZKuLfo8nzySxtfwO6B_20ixRuKv5DRzMLc8rxLAazhCPTeno-qzCIaa9cEiJ8Z6viLnl2-R6lhUepNuu-8_vpL3otK_Px0N2kIJEFm4RKbJ3I8Ye4FfMOKmLbFKMSojEorHC9jlJRLkHzjjAUPOBp1-RSTVGhVCk_Ol6Hd5Hx7YIn8XOUKnscrd0LMKVGeKePyxV5Gn6ZlclVCWbhr3cjs1IVkRV9DWcqtPeb672vDw1FEsIuH0o43oTZgoB2syw',
	},
	{
		rank: 2,
		name: 'Bror',
		score: '9.2',
		blurb: 'Røff kutting, eksepsjonell crunch og en signatur krydderblanding.',
		updated: '15.05.2024',
	},
	{
		rank: 3,
		name: 'Kef',
		score: '8.9',
		blurb: 'Den klassiske stilen perfeksjonert. Alltid varme, alltid sprø.',
		updated: '18.05.2024',
	},
];
---

<Container as="section" class="leaderboard-wrap" id="leaderboard">
	<div class="section-head">
		<h2 class="section-title">Top_03</h2>
		<span class="section-vol meta">VOL. 2026.01</span>
	</div>

	<div class="cards">
		{
			leaders.map((entry) => (
				<article class:list={['card', entry.rank === 1 && 'card-featured']}>
					<div class="card-top">
						<span
							class:list={['rank', entry.rank === 1 ? 'rank-gold' : 'rank-muted']}
							aria-label={`Rank ${entry.rank}`}
						>
							#{String(entry.rank).padStart(2, '0')}
						</span>
						<span
							class:list={[
								'score-chip',
								entry.rank === 1 ? 'score-chip-gold' : 'score-chip-muted',
							]}
						>
							SCORE: {entry.score}
						</span>
					</div>

					<div class="card-body">
						<h3 class="venue">{entry.name}</h3>
						<p class:list={['blurb', entry.rank === 1 && 'blurb-italic']}>{entry.blurb}</p>
					</div>

					{entry.image && (
						<div class="media">
							<img
								src={entry.image}
								alt=""
								width={800}
								height={384}
								loading="lazy"
								decoding="async"
								class="media-img"
							/>
						</div>
					)}

					<div class="card-foot">
						<span class="meta updated">Oppdatert: {entry.updated}</span>
						{entry.rank === 1 ? (
							<span
								class="material-symbols-outlined icon-star"
								aria-hidden="true"
								style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24"
							>
								star
							</span>
						) : (
							<span class="material-symbols-outlined icon-arrow" aria-hidden="true">
								arrow_forward
							</span>
						)}
					</div>
				</article>
			))
		}
	</div>

	<div class="cta-wrap">
		<a class="cta-primary" href="#archive">Se alle (42)</a>
	</div>
</Container>

<style>
	.leaderboard-wrap {
		padding-top: var(--space-2);
		max-width: 28rem;
		margin-inline: auto;
	}

	.section-head {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: var(--space-2);
		padding-bottom: var(--space-2);
		margin-bottom: var(--space-4);
		border-bottom: 4px solid var(--color-accent-gold);
	}

	.section-title {
		margin: 0;
		font-family: var(--font-display);
		font-size: var(--text-headline-md);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: -0.04em;
		line-height: 1;
		color: var(--color-text);
	}

	.section-vol {
		opacity: 0.6;
		white-space: nowrap;
	}

	.meta {
		font-family: var(--font-meta);
		font-size: var(--text-meta);
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.cards {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}

	@media (min-width: 900px) {
		.leaderboard-wrap {
			max-width: none;
		}

		.cards {
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: var(--space-3);
			align-items: stretch;
		}

		.card {
			display: flex;
			flex-direction: column;
		}

		.card .card-body {
			flex: 1;
		}
	}

	.card {
		position: relative;
		padding: var(--space-4);
		background: var(--color-surface);
		border-bottom: 4px solid var(--color-text);
		transition: background 0.2s ease;
	}

	.card-featured {
		transition: transform 0.2s ease, background 0.2s ease;
	}

	.card-featured:hover {
		background: var(--color-surface-2);
	}

	.card-top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--space-2);
		margin-bottom: var(--space-3);
	}

	.rank {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 8vw, 3.25rem);
		font-weight: 700;
		font-style: italic;
		line-height: 0.95;
		letter-spacing: -0.03em;
	}

	.rank-gold {
		color: var(--color-accent-gold);
	}

	.rank-muted {
		color: var(--color-text);
		opacity: 0.4;
	}

	.score-chip {
		font-family: var(--font-meta);
		font-size: var(--text-meta);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.35rem 0.5rem;
		border: var(--border-thin) solid;
		flex-shrink: 0;
	}

	.score-chip-gold {
		color: var(--color-accent-gold);
		border-color: var(--color-accent-gold);
	}

	.score-chip-muted {
		color: color-mix(in oklab, var(--color-text) 60%, transparent);
		border-color: color-mix(in oklab, var(--color-text) 20%, transparent);
	}

	.venue {
		margin: 0 0 var(--space-2);
		font-family: var(--font-display);
		font-size: var(--text-headline-md);
		font-weight: 500;
		color: var(--color-text);
		line-height: 1.15;
	}

	.blurb {
		margin: 0;
		font-size: var(--text-body-md);
		line-height: 1.5;
		color: var(--color-text-muted);
	}

	.blurb-italic {
		font-style: italic;
	}

	.media {
		margin: var(--space-3) 0 var(--space-3);
		aspect-ratio: 16 / 9;
		background: var(--color-surface-3);
		overflow: hidden;
		max-height: 12rem;
	}

	.media-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: grayscale(1);
		transition: filter 0.5s ease;
	}

	.card-featured:hover .media-img {
		filter: grayscale(0);
	}

	.card-foot {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: var(--space-2);
	}

	.updated {
		color: var(--color-text-muted);
		text-transform: none;
		letter-spacing: 0.05em;
		font-size: 0.6875rem;
	}

	.icon-star {
		color: var(--color-accent-red-deep);
		font-size: 1.5rem;
	}

	.icon-arrow {
		color: var(--color-text);
		font-size: 1.5rem;
	}

	.cta-wrap {
		padding-top: var(--space-5);
	}

	.cta-primary {
		display: block;
		width: 100%;
		padding: var(--space-4) var(--space-3);
		text-align: center;
		font-family: var(--font-meta);
		font-size: var(--text-label);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: #0a0a0a;
		background: var(--color-accent-gold);
		border: 2px solid #0a0a0a;
		text-decoration: none;
		transition: background 0.2s ease, color 0.2s ease, transform 0.15s ease;
	}

	.cta-primary:hover {
		background: var(--color-text);
		color: var(--color-bg);
	}

	.cta-primary:active {
		transform: scale(0.98);
	}
</style>
