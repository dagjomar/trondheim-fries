---
import Container from '../primitives/Container.astro';
import VenueCard from './VenueCard.astro';
import { venues } from '../../data/venues';
---

<Container as="section" class="leaderboard-wrap" id="arkiv">
	<div class="section-head" id="leaderboard">
		<h2 class="section-title">Fasit</h2>
		<p class="section-kicker">Topp-sjiktet i Trondheim</p>
	</div>

	<p class="section-lede">
		Rekkefølgen er ikke rangering — stedene her står i samme klasse. Listen oppdateres
		fortløpende når fasit endrer seg.
	</p>

	<div class="cards">
		{venues.map((venue, i) => (
			<VenueCard venue={venue} imageLoading={i === 0 ? 'eager' : 'lazy'} />
		))}
	</div>
</Container>

<style>
	.leaderboard-wrap {
		padding-top: var(--space-2);
		max-width: 28rem;
		margin-inline: auto;
	}

	.section-head {
		padding-bottom: var(--space-2);
		margin-bottom: var(--space-2);
		border-bottom: 4px solid var(--color-accent-gold);
	}

	.section-title {
		margin: 0;
		font-family: var(--font-display);
		font-size: var(--text-headline-md);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: -0.04em;
		line-height: 1;
		color: var(--color-text);
	}

	.section-kicker {
		margin: var(--space-2) 0 0;
		font-family: var(--font-meta);
		font-size: var(--text-meta);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-text-muted);
		line-height: 1.2;
	}

	.section-lede {
		margin: 0 0 var(--space-4);
		font-size: var(--text-body-md);
		line-height: 1.5;
		color: var(--color-text-muted);
	}

	.cards {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}

	@media (min-width: 900px) {
		.leaderboard-wrap {
			max-width: none;
		}

		.cards {
			display: grid;
			grid-template-columns: repeat(
				auto-fit,
				minmax(min(100%, 18rem), 1fr)
			);
			gap: var(--space-3);
			align-items: stretch;
		}
	}
</style>
