---
import Container from '../primitives/Container.astro';
import VenueCard from './VenueCard.astro';
import { venues } from '../../data/venues';
---

<Container as="section" class="leaderboard-wrap" id="arkiv">
	<div class="section-head" id="leaderboard">
		<h2 class="section-title">Rangering</h2>
	</div>

	<p class="section-lede">
		Så langt er disse rangert blant de beste stedene for pommes frites i Trondheim.
	</p>

	<div class="cards">
		{venues.map((venue) => <VenueCard venue={venue} />)}
	</div>
</Container>

<style>
	.leaderboard-wrap {
		padding-top: var(--space-2);
		max-width: 28rem;
		margin-inline: auto;
		scroll-margin-top: var(--top-bar-height);
	}

	.section-head {
		padding-bottom: var(--space-2);
		margin-bottom: var(--space-2);
		border-bottom: 4px solid var(--color-accent-gold);
		scroll-margin-top: var(--top-bar-height);
	}

	.section-title {
		margin: 0;
		font-family: var(--font-display);
		font-size: var(--text-headline-md);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: -0.04em;
		line-height: 1;
		color: var(--color-text);
	}

	.section-lede {
		margin: 0 0 var(--space-4);
		font-size: var(--text-body-md);
		line-height: 1.5;
		color: var(--color-text-muted);
	}

	.cards {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}

	@media (min-width: 900px) {
		.leaderboard-wrap {
			max-width: none;
		}

		.cards {
			display: grid;
			grid-template-columns: repeat(
				auto-fit,
				minmax(min(100%, 18rem), 1fr)
			);
			gap: var(--space-3);
			align-items: stretch;
		}
	}
</style>
