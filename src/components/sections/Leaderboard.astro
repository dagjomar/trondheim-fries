---
import Container from '../primitives/Container.astro';
import VenueCard from './VenueCard.astro';
import { venues } from '../../data/venues';

const total = venues.length;
---

<Container as="section" class="leaderboard-wrap" id="arkiv">
	<div class="section-head" id="leaderboard">
		<h2 class="section-title">Top_03</h2>
		<span class="section-vol meta">VOL. 2026.01 · {total} OPPFØRINGER</span>
	</div>

	<p class="section-lede">
		Kuraterte steder på forsiden — ingen egen underside per sted i milepæl 1.
	</p>

	<div class="cards">
		{venues.map((venue) => <VenueCard venue={venue} />)}
	</div>
</Container>

<style>
	.leaderboard-wrap {
		padding-top: var(--space-2);
		max-width: 28rem;
		margin-inline: auto;
		scroll-margin-top: var(--top-bar-height);
	}

	.section-head {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: var(--space-2);
		padding-bottom: var(--space-2);
		margin-bottom: var(--space-2);
		border-bottom: 4px solid var(--color-accent-gold);
		scroll-margin-top: var(--top-bar-height);
	}

	.section-title {
		margin: 0;
		font-family: var(--font-display);
		font-size: var(--text-headline-md);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: -0.04em;
		line-height: 1;
		color: var(--color-text);
	}

	.section-vol {
		opacity: 0.6;
		text-align: right;
		max-width: 12rem;
	}

	.section-lede {
		margin: 0 0 var(--space-4);
		font-size: var(--text-body-md);
		line-height: 1.5;
		color: var(--color-text-muted);
	}

	.meta {
		font-family: var(--font-meta);
		font-size: var(--text-meta);
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.cards {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}

	@media (min-width: 900px) {
		.leaderboard-wrap {
			max-width: none;
		}

		.cards {
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: var(--space-3);
			align-items: stretch;
		}
	}
</style>
