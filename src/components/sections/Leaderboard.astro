---
import Container from '../primitives/Container.astro';
import FriesScore from '../FriesScore.astro';
import VenueCard from './VenueCard.astro';
import {
	TIER_DESCRIPTIONS,
	TIER_LABELS,
	TIER_ORDER,
	venues,
} from '../../data/venues';

const grouped = [...TIER_ORDER].map((tier) => ({
	tier,
	label: TIER_LABELS[tier],
	description: TIER_DESCRIPTIONS[tier],
	items: venues.filter((v) => v.tier === tier),
}));
---

<Container as="section" class="leaderboard-wrap" id="arkiv">
	<h2 id="leaderboard" class="sr-only" tabindex="-1">Sjikt og steder</h2>
	{
		grouped.map((group, groupIndex) => (
			<section class="tier-block" aria-labelledby={`sjikt-${group.tier}-title`}>
				<header class="tier-header">
					<div class="tier-title-row">
						<h2 id={`sjikt-${group.tier}-title`} class="tier-title">
							{group.label}
						</h2>
						<FriesScore tier={group.tier} size="xl" />
					</div>
					<p class="tier-intro">{group.description}</p>
				</header>
				{group.items.length === 0 ? (
					<p class="tier-empty">Ingen steder listet i dette sjiktet ennå.</p>
				) : (
					<div class="cards">
						{group.items.map((venue, i) => (
							<VenueCard
								venue={venue}
								imageLoading={
									groupIndex === 0 && i === 0 ? 'eager' : 'lazy'
								}
							/>
						))}
					</div>
				)}
			</section>
		))
	}
</Container>

<style>
	.leaderboard-wrap {
		position: relative;
		max-width: 28rem;
		margin-inline: auto;
		padding-top: var(--space-2);
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.tier-block {
		margin: 0;
		padding: 0;
	}

	.tier-block + .tier-block {
		margin-top: var(--space-6);
		padding-top: var(--space-6);
		border-top: 2px solid var(--color-outline);
	}

	.tier-header {
		margin: 0 0 var(--space-4);
	}

	.tier-title-row {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-end;
		justify-content: flex-start;
		gap: var(--space-2) var(--space-3);
		margin-bottom: var(--space-2);
		font-family: var(--font-display);
		font-size: var(--text-headline-lg);
		line-height: 1.05;
	}

	.tier-title-row :global(.fries-score.fries-score--xl .fries-score__img) {
		height: max(1.75rem, min(3.125rem, 0.74em));
	}

	.tier-title {
		margin: 0;
		flex: 0 1 auto;
		min-width: 0;
		font-family: inherit;
		font-size: inherit;
		font-weight: 500;
		letter-spacing: -0.03em;
		line-height: inherit;
		color: var(--color-text);
	}

	.tier-intro {
		margin: 0;
		max-width: 36rem;
		font-size: var(--text-body-md);
		line-height: 1.5;
		color: var(--color-text-muted);
	}

	.tier-empty {
		margin: 0;
		font-family: var(--font-meta);
		font-size: var(--text-meta);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-text-muted);
		opacity: 0.75;
		line-height: 1.4;
	}

	.cards {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}

	@media (min-width: 900px) {
		.leaderboard-wrap {
			max-width: none;
		}

		.cards {
			display: grid;
			grid-template-columns: repeat(
				auto-fit,
				minmax(min(100%, 18rem), 1fr)
			);
			gap: var(--space-3);
			align-items: stretch;
		}
	}
</style>
