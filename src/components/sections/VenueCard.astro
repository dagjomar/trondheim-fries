---
import { TOP_TIER_LABEL, type Venue } from '../../data/venues';

interface Props {
	venue: Venue;
	imageLoading?: 'eager' | 'lazy';
}

const { venue, imageLoading = 'lazy' } = Astro.props;
---

<article class="card">
	<div class="card-top">
		<span class="tier-badge" aria-label={TOP_TIER_LABEL}>
			{TOP_TIER_LABEL}
		</span>
		<!--span class="score-chip">
			POENG: {venue.score}
		</span-->
	</div>

	<div class="card-body">
		<h3 class="venue">{venue.name}</h3>
		<p class="blurb">{venue.blurb}</p>
		<p class="traits meta">{venue.traits}</p>
	</div>

	<div class="media">
		<img
			src={venue.image}
			alt={`${venue.name}: pommes frites`}
			width={800}
			height={450}
			loading={imageLoading}
			decoding="async"
			class="media-img"
		/>
	</div>

	<div class="card-links">
		<a class="link-out" href={venue.mapUrl} target="_blank" rel="noopener noreferrer">
			<span class="material-symbols-outlined link-ic" aria-hidden="true">map</span>
			Kart
		</a>
		{
			venue.websiteUrl && (
				<a class="link-out" href={venue.websiteUrl} target="_blank" rel="noopener noreferrer">
					<span class="material-symbols-outlined link-ic" aria-hidden="true">language</span>
					Nettsted
				</a>
			)
		}
	</div>

	<div class="card-foot">
		<span class="meta updated">Oppdatert: {venue.updated}</span>
	</div>
</article>

<style>
	.card {
		position: relative;
		padding: var(--space-4);
		background: var(--color-surface);
		border-bottom: 4px solid var(--color-text);
		transition: background 0.2s ease;
	}

	.card:hover {
		background: var(--color-surface-2);
	}

	.card-top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--space-2);
		margin-bottom: var(--space-3);
	}

	.tier-badge {
		font-family: var(--font-display);
		font-size: clamp(1.5rem, 5vw, 2rem);
		font-weight: 700;
		font-style: italic;
		line-height: 1.05;
		letter-spacing: -0.03em;
		color: var(--color-accent-gold);
		max-width: 12rem;
	}

	.score-chip {
		font-family: var(--font-meta);
		font-size: var(--text-meta);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.35rem 0.5rem;
		border: var(--border-thin) solid var(--color-accent-gold);
		flex-shrink: 0;
		color: var(--color-accent-gold);
	}

	.venue {
		margin: 0 0 var(--space-2);
		font-family: var(--font-display);
		font-size: var(--text-headline-md);
		font-weight: 500;
		color: var(--color-text);
		line-height: 1.15;
	}

	.blurb {
		margin: 0;
		font-size: var(--text-body-md);
		line-height: 1.5;
		color: var(--color-text-muted);
	}

	.traits {
		margin: var(--space-2) 0 0;
		color: var(--color-text-muted);
		opacity: 0.85;
	}

	.meta {
		font-family: var(--font-meta);
		font-size: var(--text-meta);
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.media {
		margin: var(--space-3) 0 var(--space-3);
		aspect-ratio: 16 / 9;
		background: var(--color-surface-3);
		overflow: hidden;
		max-height: 12rem;
	}

	.media-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: grayscale(1);
		transition: filter 0.5s ease;
	}

	.card:hover .media-img {
		filter: grayscale(0);
	}

	.card-links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		margin-bottom: var(--space-3);
		padding-bottom: var(--space-3);
		border-bottom: var(--border-thin) solid var(--color-outline);
	}

	.link-out {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-family: var(--font-meta);
		font-size: var(--text-label);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-accent-gold);
		text-decoration: none;
		transition: color 0.18s ease;
	}

	.link-out:hover {
		color: var(--color-accent-gold-dim);
	}

	.link-ic {
		font-size: 1.125rem;
	}

	.card-foot {
		display: flex;
		align-items: center;
		gap: var(--space-2);
	}

	.updated {
		color: var(--color-text-muted);
		text-transform: none;
		letter-spacing: 0.05em;
		font-size: 0.6875rem;
	}

	@media (min-width: 900px) {
		.card {
			display: flex;
			flex-direction: column;
		}

		.card-body {
			flex: 1;
		}
	}
</style>
