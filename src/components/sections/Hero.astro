---
import Container from '../primitives/Container.astro';
import Button from '../primitives/Button.astro';

/** Local asset: `public/images/hero-frites.jpg` (see `public/images/CREDITS.txt`). */
const heroImage = '/images/trondheim-fries.jpg';
---

<Container as="section" class="hero-guiden" id="hero">
	<div class="hero-guiden-inner">
		<div class="hero-copy">
			<h1 class="hero-title">Når du bare vil ha litt god pommes frites…</h1>
			<p class="hero-intro">
				Enten du er på besøk eller bor her fast, hender det at du bare vil ha enkle og raske fries, ikke sant?
				Denne siden hjelper deg med å finne den absolutte beste crunchen i Trondheim.
			</p>
			<div class="hero-cta">
				<Button href="#leaderboard" class="hero-cta-primary">Se lederne</Button>
			</div>
		</div>
		<div class="hero-visual">
			<img
				class="hero-img"
				src={heroImage}
				alt="Nærbilde av sprø, gyllen pommes frites"
				width="4000"
				height="2667"
				loading="eager"
				decoding="async"
			/>
			<div class="hero-visual-scrim"></div>
			<div class="hero-visual-accent" aria-hidden="true">
				<span
					class="material-symbols-outlined hero-chevron"
					style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;"
				>
					expand_more
				</span>
			</div>
		</div>
	</div>
</Container>

<style>
	/* Same rhythm as arkiv: `.container` + `gap: var(--space-3)` + 2fr | 1fr from 900px. */
	.hero-guiden {
		padding-top: 0;
	}

	.hero-guiden-inner {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-3);
		min-height: min(32rem, 70dvh);
	}

	.hero-copy {
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: var(--space-4) var(--space-3);
		background: var(--color-surface);
		border: var(--border-thin) solid var(--color-outline);
		overflow: hidden;
	}

	.hero-title {
		margin: 0 0 var(--space-3);
		font-family: var(--font-display);
		font-size: clamp(2rem, 5.5vw, 3rem);
		font-weight: 600;
		line-height: 1.08;
		letter-spacing: -0.02em;
		max-width: 18ch;
		color: var(--color-text);
	}

	.hero-intro {
		margin: 0 0 var(--space-4);
		font-size: var(--text-body-md);
		line-height: 1.6;
		color: var(--color-text-muted);
		max-width: 38ch;
	}

	.hero-cta {
		display: block;
		margin-top: var(--space-1);
	}

	.hero-cta :global(.hero-cta-primary) {
		width: 100%;
		max-width: 22rem;
		padding: 1.05rem 1.5rem;
		font-size: 0.8125rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		border-width: 2px;
		text-decoration: none;
		box-sizing: border-box;
		transition: transform 0.15s ease, filter 0.15s ease;
	}

	.hero-cta :global(.hero-cta-primary:hover) {
		filter: brightness(1.06);
	}

	.hero-cta :global(.hero-cta-primary:active) {
		transform: scale(0.99);
	}

	.hero-visual {
		position: relative;
		overflow: hidden;
		background: var(--color-surface-3);
		min-height: 14rem;
		border: var(--border-thin) solid var(--color-outline);
	}

	.hero-img {
		width: 100%;
		height: 100%;
		min-height: 14rem;
		object-fit: cover;
		display: block;
	}

	.hero-visual-scrim {
		pointer-events: none;
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, color-mix(in oklab, var(--color-bg) 55%, transparent), transparent);
	}

	.hero-visual-accent {
		position: absolute;
		bottom: var(--space-3);
		right: var(--space-3);
	}

	.hero-chevron {
		font-size: 3rem;
		color: var(--color-accent-gold);
		line-height: 1;
	}

	@media (min-width: 900px) {
		.hero-guiden-inner {
			grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
			align-items: stretch;
			/* Shorter than mobile-relative 75dvh: less empty band above copy on wide viewports */
			min-height: min(30rem, 62dvh);
		}

		.hero-copy {
			justify-content: flex-start;
			padding: var(--space-4) var(--space-4) var(--space-5);
		}

		.hero-visual {
			min-height: 100%;
		}

		.hero-img {
			min-height: 100%;
		}

		.hero-cta :global(.hero-cta-primary) {
			max-width: 26rem;
			padding: 1.15rem 1.75rem;
			font-size: 0.875rem;
		}
	}
</style>
