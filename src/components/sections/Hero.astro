---
import Button from '../primitives/Button.astro';

const heroImage =
	'https://lh3.googleusercontent.com/aida-public/AB6AXuCMGTASeKhslK6NEFR9qfD2hnVm22O0m_eiMOmPop2jYIIb74BXwI3sf2s30GITCXT-VwvRflhTtXu1T9kix4C5_ESsncQgr0J68I9W2Pt4vnfi4_MJ1vl6oCv2y8L18RjOianC-ARW-iF08WLXkLRJzweGQPWswLIeTGHBqc9Afv1gUBBWxPTc2-vKbT9cWy10zzjfh3HjVicGsBU2mIHQ_rn9Vja3_r3J_FoYgXXRxST8f5WLroSOWkICGjPGBYhK9eC0u7nG8w';
---

<section class="hero-guiden">
	<div class="hero-guiden-inner">
		<div class="hero-copy">
			<h1 class="hero-title">Når du bare vil ha pommes frites…</h1>
			<p class="hero-intro">
				Enten du er på besøk eller bor her fast, hender det at du bare vil ha enkle og raske fries, ikke sant?
				Denne siden er kuratert for å finne den absolutte beste crunchen i Trondheim.
			</p>
			<div class="chips">
				<span class="chip chip-solid">ETABL. 2024</span>
				<span class="chip chip-outline">TRD // NO</span>
			</div>
			<div class="hero-cta">
				<Button href="#leaderboard">Se lederne</Button>
				<Button href="#archive" variant="outline">Utforsk arkivet</Button>
			</div>
		</div>
		<div class="hero-visual">
			<img
				class="hero-img"
				src={heroImage}
				alt="Frityrstekt perfeksjon"
				width="900"
				height="1200"
				loading="eager"
				decoding="async"
			/>
			<div class="hero-visual-scrim"></div>
			<div class="hero-visual-accent" aria-hidden="true">
				<span
					class="material-symbols-outlined hero-chevron"
					style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;"
				>
					expand_more
				</span>
			</div>
		</div>
	</div>
</section>

<style>
	.hero-guiden {
		grid-column: 1 / -1;
		width: 100vw;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
		min-height: min(921px, 92dvh);
		border-bottom: var(--border-thin) solid var(--color-outline);
	}

	.hero-guiden-inner {
		display: grid;
		grid-template-columns: 1fr;
		min-height: inherit;
	}

	.hero-copy {
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: var(--space-4) var(--space-3);
		background: var(--color-surface);
		border-bottom: var(--border-thin) solid var(--color-outline);
	}

	.hero-title {
		margin: 0 0 var(--space-3);
		font-family: var(--font-display);
		font-size: clamp(2rem, 5.5vw, 3rem);
		font-weight: 600;
		line-height: 1.08;
		letter-spacing: -0.02em;
		max-width: 18ch;
		color: var(--color-text);
	}

	.hero-intro {
		margin: 0 0 var(--space-5);
		font-size: var(--text-body-md);
		line-height: 1.6;
		color: var(--color-text-muted);
		max-width: 38ch;
	}

	.chips {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		margin-bottom: var(--space-4);
	}

	.chip {
		font-family: var(--font-meta);
		font-size: var(--text-meta);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		padding: 0.35rem 0.75rem;
	}

	.chip-solid {
		background: var(--color-accent-red);
		color: #fff;
		border: var(--border-thin) solid var(--color-accent-red);
	}

	.chip-outline {
		color: var(--color-outline-strong);
		border: var(--border-thin) solid var(--color-outline-strong);
		background: transparent;
	}

	.hero-cta {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.hero-visual {
		position: relative;
		overflow: hidden;
		background: var(--color-surface-3);
		min-height: 16rem;
	}

	.hero-img {
		width: 100%;
		height: 100%;
		min-height: 16rem;
		object-fit: cover;
		display: block;
	}

	.hero-visual-scrim {
		pointer-events: none;
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, color-mix(in oklab, var(--color-bg) 55%, transparent), transparent);
	}

	.hero-visual-accent {
		position: absolute;
		bottom: var(--space-3);
		right: var(--space-3);
	}

	.hero-chevron {
		font-size: 3rem;
		color: var(--color-accent-gold);
		line-height: 1;
	}

	@media (min-width: 900px) {
		.hero-guiden-inner {
			grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
		}

		.hero-copy {
			border-right: var(--border-thin) solid var(--color-outline);
			border-bottom: none;
			padding: var(--space-6) var(--space-5);
		}

		.hero-visual {
			min-height: 100%;
		}

		.hero-img {
			min-height: 100%;
			aspect-ratio: auto;
			max-height: 921px;
		}
	}
</style>
