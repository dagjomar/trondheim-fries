<nav class="bottom-nav" aria-label="Hurtigvalg mobil">
	<a class="bottom-link bottom-link-active" href="#leaderboard">
		<span class="material-symbols-outlined icon-fill">bolt</span>
		<span class="label">TRENDER</span>
	</a>
	<a class="bottom-link" href="#arkiv">
		<span class="material-symbols-outlined">star</span>
		<span class="label">ARKIV</span>
	</a>
	<a class="bottom-link" href="/blog">
		<span class="material-symbols-outlined">menu_book</span>
		<span class="label">VOL_01</span>
	</a>
	<a class="bottom-link bottom-link-accent" href="#">
		<span class="material-symbols-outlined">add_box</span>
		<span class="label">SEND INN</span>
	</a>
</nav>

<style>
	.bottom-nav {
		display: flex;
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		z-index: 50;
		height: 5rem;
		justify-content: space-around;
		align-items: center;
		padding: 0 var(--space-2);
		background: var(--color-nav-bg);
		border-top: var(--border-nav) solid var(--color-text);
	}

	@media (min-width: 768px) {
		.bottom-nav {
			display: none;
		}
	}

	.bottom-link {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.2rem;
		padding: var(--space-1) var(--space-2);
		color: color-mix(in oklab, var(--color-text) 50%, transparent);
		text-decoration: none;
		font-family: var(--font-meta);
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.bottom-link:hover {
		color: var(--color-accent-gold);
	}

	.bottom-link-active {
		color: var(--color-accent-gold);
	}

	.bottom-link-accent {
		color: var(--color-accent-red-deep);
	}

	.bottom-link-accent:hover {
		color: var(--color-accent-red);
	}

	.bottom-link .material-symbols-outlined {
		font-size: 1.35rem;
	}

	.icon-fill {
		font-variation-settings: "FILL" 1, "wght" 400, "GRAD" 0, "opsz" 24;
	}
</style>
