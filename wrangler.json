{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "trondheimfries",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"routes": [
		{
			"pattern": "trondheimfries.no",
			"custom_domain": true
		}
	]
}